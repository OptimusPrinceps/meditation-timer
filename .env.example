# Secrets for the local server. Copy this file to `.env` and fill in the value.
# `.env` is gitignored — never commit it.
#
# Claude Max subscription OAuth token, used by the weight coach so it bills your
# subscription instead of the paid API. Generate it once with:
#
#     claude setup-token
#
# IMPORTANT: do NOT set ANTHROPIC_API_KEY (here or in your shell) — if set, it
# takes precedence over this token and reverts to paid API billing.
CLAUDE_CODE_OAUTH_TOKEN=
